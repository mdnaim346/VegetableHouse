<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="vegetable_house.Login" owl="1">

        <!-- Full-screen wrapper -->
        <div class="o_vh_login_page" style="
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #064e3b 0%, #065f46 30%, #047857 60%, #16a34a 100%);
            position: relative;
            overflow-y: auto;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            padding: 40px 24px;
        ">
            <!-- Checking Auth Loader -->
            <t t-if="state.checkingAuth">
                <div class="text-center text-white">
                    <i class="fa fa-spinner fa-spin fa-3x mb-3"/>
                    <div style="font-weight: 500;">Verifying session...</div>
                </div>
            </t>

            <!-- Card -->
            <div t-if="!state.checkingAuth" 
                 style="
                background: rgba(255,255,255,0.97);
                border-radius: 28px;
                padding: 44px 40px;
                width: 100%;
                max-width: 460px;
                box-shadow: 0 32px 80px rgba(0,0,0,0.28), 0 8px 24px rgba(0,0,0,0.12);
                position: relative;
                z-index: 1;
                box-sizing: border-box;
            ">

                <!-- ─── BRAND HEADER ─── -->
                <div class="text-center" style="margin-bottom: 28px;">
                    <div style="
                        width: 68px; height: 68px;
                        border-radius: 18px;
                        background: linear-gradient(135deg, #16a34a, #065f46);
                        display: inline-flex;
                        align-items: center;
                        justify-content: center;
                        margin-bottom: 14px;
                        box-shadow: 0 8px 24px rgba(22,163,74,0.35);
                    ">
                        <i class="fa fa-leaf" style="font-size: 28px; color: #ffffff;"/>
                    </div>
                    <h1 style="font-size: 24px; font-weight: 800; color: #064e3b; margin-bottom: 4px; letter-spacing: -0.5px;">
                        Vegetable House
                    </h1>
                    <p style="color: #6b7280; font-size: 13px; margin: 0;">
                        <t t-if="state.mode === 'login'">Sign in to dashboard</t>
                        <t t-else="">Create your account to get started</t>
                    </p>
                </div>

                <!-- ─── MODE TABS ─── -->
                <div style="
                    display: flex;
                    background: #f3f4f6;
                    border-radius: 14px;
                    padding: 4px;
                    margin-bottom: 24px;
                    gap: 4px;
                ">
                    <button type="button" t-on-click="switchToLogin" style="
                        flex: 1;
                        padding: 9px 0;
                        border: none;
                        border-radius: 11px;
                        font-size: 14px;
                        font-weight: 600;
                        cursor: pointer;
                        transition: all 0.2s;
                        background: none;
                    " t-att-style="state.mode === 'login' ? 'background:#ffffff;color:#065f46;box-shadow:0 2px 8px rgba(0,0,0,0.1);' : 'background:transparent;color:#9ca3af;'">
                        <i class="fa fa-sign-in" style="margin-right:6px;"/>Sign In
                    </button>
                    <button type="button" t-on-click="switchToRegister" style="
                        flex: 1;
                        padding: 9px 0;
                        border: none;
                        border-radius: 11px;
                        font-size: 14px;
                        font-weight: 600;
                        cursor: pointer;
                        transition: all 0.2s;
                        background: none;
                    " t-att-style="state.mode === 'register' ? 'background:#ffffff;color:#065f46;box-shadow:0 2px 8px rgba(0,0,0,0.1);' : 'background:transparent;color:#9ca3af;'">
                        <i class="fa fa-user-plus" style="margin-right:6px;"/>Register
                    </button>
                </div>

                <!-- ─── SUCCESS ALERT ─── -->
                <t t-if="state.successMessage">
                    <div style="
                        background: #f0fdf4;
                        border: 1px solid #bbf7d0;
                        border-radius: 12px;
                        padding: 12px 16px;
                        margin-bottom: 18px;
                        display: flex;
                        align-items: center;
                        gap: 10px;
                    ">
                        <i class="fa fa-check-circle" style="color: #16a34a; font-size: 16px;"/>
                        <span style="color: #166534; font-size: 14px; font-weight: 500;" t-esc="state.successMessage"/>
                    </div>
                </t>

                <!-- ─── ERROR ALERT ─── -->
                <t t-if="state.error">
                    <div style="
                        background: #fef2f2;
                        border: 1px solid #fecaca;
                        border-radius: 12px;
                        padding: 12px 16px;
                        margin-bottom: 18px;
                        display: flex;
                        align-items: center;
                        gap: 10px;
                    ">
                        <i class="fa fa-exclamation-circle" style="color: #ef4444; font-size: 16px;"/>
                        <span style="color: #b91c1c; font-size: 14px; font-weight: 500;" t-esc="state.error"/>
                    </div>
                </t>

                <!-- ══════════════════════════════════════════════════ -->
                <!--                  LOGIN FORM                        -->
                <!-- ══════════════════════════════════════════════════ -->
                <t t-if="state.mode === 'login'">

                    <!-- Username -->
                    <div style="margin-bottom: 16px;">
                        <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:7px;"> User name
                        </label>
                        <div style="position:relative;">
                            <i class="fa fa-user" style="position:absolute;left:13px;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:13px;"/>
                            <input
                                id="vh_login_username"
                                type="text"
                                autocomplete="username"
                                placeholder="Enter your username"
                                t-att-value="state.username"
                                t-on-input="(ev) => { state.username = ev.target.value; state.error = ''; }"
                                t-on-keydown="onLoginKeyDown"
                                style="width:100%;padding:12px 12px 12px 38px;border:1.5px solid #e5e7eb;border-radius:12px;font-size:14px;color:#111827;background:#f9fafb;outline:none;box-sizing:border-box;"
                            />
                        </div>
                    </div>

                    <!-- Password -->
                    <div style="margin-bottom: 26px;">
                        <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:7px;">
                            Password
                        </label>
                        <div style="position:relative;">
                            <i class="fa fa-lock" style="position:absolute;left:13px;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:13px;"/>
                            <input
                                id="vh_login_password"
                                t-att-type="state.showPassword ? 'text' : 'password'"
                                autocomplete="current-password"
                                placeholder="Enter your password"
                                t-att-value="state.password"
                                t-on-input="(ev) => { state.password = ev.target.value; state.error = ''; }"
                                t-on-keydown="onLoginKeyDown"
                                style="width:100%;padding:12px 40px 12px 38px;border:1.5px solid #e5e7eb;border-radius:12px;font-size:14px;color:#111827;background:#f9fafb;outline:none;box-sizing:border-box;"
                            />
                            <button type="button" t-on-click="togglePassword" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#9ca3af;padding:4px;">
                                <i t-att-class="state.showPassword ? 'fa fa-eye-slash' : 'fa fa-eye'" style="font-size:13px;"/>
                            </button>
                        </div>
                    </div>
                    <button
                        id="vh_login_submit"
                        type="button"
                        t-att-disabled="state.loading"
                        t-on-click="onLogin"
                        style="
                            width:100%;padding:13px;
                            background:linear-gradient(135deg,#16a34a,#065f46);
                            color:#ffffff;border:none;border-radius:14px;
                            font-size:15px;font-weight:700;cursor:pointer;
                            box-shadow:0 6px 20px rgba(22,163,74,0.35);
                            display:flex;align-items:center;justify-content:center;gap:10px;
                            opacity: 1;
                        "
                    >
                        <t t-if="state.loading">
                            <i class="fa fa-spinner fa-spin"/>
                            <span>Signing in...</span>
                        </t>
                        <t t-else="">
                            <i class="fa fa-sign-in"/>
                            <span>Sign In</span>
                        </t>
                    </button>

                    <p style="text-align:center;margin-top:18px;font-size:13px;color:#6b7280;">
                        Don't have an account?&#160;
                        <a t-on-click="switchToRegister" style="color:#16a34a;font-weight:600;cursor:pointer;text-decoration:none;">
                            Register here
                        </a>
                    </p>

                </t>

                <!-- ══════════════════════════════════════════════════ -->
                <!--                 REGISTER FORM                      -->
                <!-- ══════════════════════════════════════════════════ -->
                <t t-if="state.mode === 'register'">

                    <!-- Full Name -->
                    <div style="margin-bottom:14px;">
                        <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:7px;">Full Name <span style="color:#ef4444;">*</span></label>
                        <div style="position:relative;">
                            <i class="fa fa-id-card" style="position:absolute;left:13px;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:13px;"/>
                            <input
                                id="vh_reg_name"
                                type="text"
                                placeholder="Your full name"
                                t-att-value="state.regName"
                                t-on-input="(ev) => { state.regName = ev.target.value; state.error = ''; }"
                                t-on-keydown="onRegisterKeyDown"
                                style="width:100%;padding:11px 12px 11px 38px;border:1.5px solid #e5e7eb;border-radius:12px;font-size:14px;color:#111827;background:#f9fafb;outline:none;box-sizing:border-box;"
                            />
                        </div>
                    </div>

                    <!-- Username -->
                    <div style="margin-bottom:14px;">
                        <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:7px;">Username <span style="color:#ef4444;">*</span></label>
                        <div style="position:relative;">
                            <i class="fa fa-at" style="position:absolute;left:13px;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:13px;"/>
                            <input
                                id="vh_reg_username"
                                type="text"
                                placeholder="Choose a username"
                                t-att-value="state.regUsername"
                                t-on-input="(ev) => { state.regUsername = ev.target.value; state.error = ''; }"
                                t-on-keydown="onRegisterKeyDown"
                                style="width:100%;padding:11px 12px 11px 38px;border:1.5px solid #e5e7eb;border-radius:12px;font-size:14px;color:#111827;background:#f9fafb;outline:none;box-sizing:border-box;"
                            />
                        </div>
                    </div>

                    <!-- Email -->
                    <div style="margin-bottom:14px;">
                        <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:7px;">Email Address <span style="color:#ef4444;">*</span></label>
                        <div style="position:relative;">
                            <i class="fa fa-envelope" style="position:absolute;left:13px;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:13px;"/>
                            <input
                                id="vh_reg_email"
                                type="email"
                                placeholder="your@email.com"
                                t-att-value="state.regEmail"
                                t-on-input="(ev) => { state.regEmail = ev.target.value; state.error = ''; }"
                                t-on-keydown="onRegisterKeyDown"
                                style="width:100%;padding:11px 12px 11px 38px;border:1.5px solid #e5e7eb;border-radius:12px;font-size:14px;color:#111827;background:#f9fafb;outline:none;box-sizing:border-box;"
                            />
                        </div>
                    </div>

                    <!-- Password -->
                    <div style="margin-bottom:14px;">
                        <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:7px;">Password <span style="color:#ef4444;">*</span> <span style="font-weight:400;color:#9ca3af;">(min. 6 chars)</span></label>
                        <div style="position:relative;">
                            <i class="fa fa-lock" style="position:absolute;left:13px;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:13px;"/>
                            <input
                                id="vh_reg_password"
                                t-att-type="state.showRegPassword ? 'text' : 'password'"
                                placeholder="Create a password"
                                t-att-value="state.regPassword"
                                t-on-input="(ev) => { state.regPassword = ev.target.value; state.error = ''; }"
                                t-on-keydown="onRegisterKeyDown"
                                style="width:100%;padding:11px 40px 11px 38px;border:1.5px solid #e5e7eb;border-radius:12px;font-size:14px;color:#111827;background:#f9fafb;outline:none;box-sizing:border-box;"
                            />
                            <button type="button" t-on-click="toggleRegPassword" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#9ca3af;padding:4px;">
                                <i t-att-class="state.showRegPassword ? 'fa fa-eye-slash' : 'fa fa-eye'" style="font-size:13px;"/>
                            </button>
                        </div>
                    </div>

                    <!-- Confirm Password -->
                    <div style="margin-bottom:14px;">
                        <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:7px;">Confirm Password <span style="color:#ef4444;">*</span></label>
                        <div style="position:relative;">
                            <i class="fa fa-lock" style="position:absolute;left:13px;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:13px;"/>
                            <input
                                id="vh_reg_confirm_password"
                                type="password"
                                placeholder="Re-enter your password"
                                t-att-value="state.regConfirmPassword"
                                t-on-input="(ev) => { state.regConfirmPassword = ev.target.value; state.error = ''; }"
                                t-on-keydown="onRegisterKeyDown"
                                style="width:100%;padding:11px 12px 11px 38px;border:1.5px solid #e5e7eb;border-radius:12px;font-size:14px;color:#111827;background:#f9fafb;outline:none;box-sizing:border-box;"
                            />
                        </div>
                    </div>

                    <!-- Address (optional) -->
                    <div style="margin-bottom:22px;">
                        <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:7px;">Delivery Address <span style="font-weight:400;color:#9ca3af;">(optional)</span></label>
                        <div style="position:relative;">
                            <i class="fa fa-map-marker" style="position:absolute;left:13px;top:14px;color:#9ca3af;font-size:13px;"/>
                            <textarea
                                id="vh_reg_address"
                                placeholder="Your delivery address"
                                t-att-value="state.regAddress"
                                t-on-input="(ev) => { state.regAddress = ev.target.value; }"
                                rows="2"
                                style="width:100%;padding:11px 12px 11px 38px;border:1.5px solid #e5e7eb;border-radius:12px;font-size:14px;color:#111827;background:#f9fafb;outline:none;resize:none;box-sizing:border-box;"
                            />
                        </div>
                    </div>

                    <!-- Register Button -->
                    <button
                        id="vh_register_submit"
                        type="button"
                        t-att-disabled="state.loading"
                        t-on-click="onRegister"
                        style="
                            width:100%;padding:13px;
                            background:linear-gradient(135deg,#16a34a,#065f46);
                            color:#ffffff;border:none;border-radius:14px;
                            font-size:15px;font-weight:700;cursor:pointer;
                            box-shadow:0 6px 20px rgba(22,163,74,0.35);
                            display:flex;align-items:center;justify-content:center;gap:10px;
                        "
                    >
                        <t t-if="state.loading">
                            <i class="fa fa-spinner fa-spin"/>
                            <span>Creating Account...</span>
                        </t>
                        <t t-else="">
                            <i class="fa fa-user-plus"/>
                            <span>Create Account</span>
                        </t>
                    </button>

                    <p style="text-align:center;margin-top:18px;font-size:13px;color:#6b7280;">
                        Already have an account?&#160;
                        <a t-on-click="switchToLogin" style="color:#16a34a;font-weight:600;cursor:pointer;text-decoration:none;">
                            Sign in here
                        </a>
                    </p>

                </t>

                <!-- Footer Note -->
                <div style="text-align:center;margin-top:20px;padding-top:16px;border-top:1px solid #f3f4f6;">
                    <p style="font-size:11px;color:#9ca3af;margin:0;">
                        <i class="fa fa-shield" style="margin-right:5px;color:#d1fae5;"/>
                        Admin credentials grant full dashboard access · Regular users see their orders only
                    </p>
                </div>

            </div>
        </div>

    </t>
</templates>
